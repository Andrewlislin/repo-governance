{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/CoaseEdge/repo-governance/schemas/repo-governance.schema.json",
  "title": "Repository governance configuration",
  "type": "object",
  "required": [
    "schemaVersion",
    "executionContractVersion",
    "governanceCompleteness",
    "runtimes",
    "executionProfiles",
    "engineVersion",
    "engineCommitSha",
    "diffFingerprintAlgorithm",
    "defaultBranch",
    "highImpactMappings",
    "testCategories",
    "testEntries",
    "testSupport",
    "testTiers",
    "commandAliases",
    "publicCommands",
    "guards",
    "policyChecks",
    "workflowAllowedEntries",
    "waiverApprovers"
  ],
  "properties": {
    "schemaVersion": { "const": 1 },
    "executionContractVersion": { "const": 1 },
    "governanceCompleteness": { "const": "complete" },
    "runtimes": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/runtime" }
    },
    "executionProfiles": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/executionProfile" }
    },
    "preset": {
      "type": "object",
      "required": ["name", "schemaVersion", "sha256"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "schemaVersion": { "const": 1 },
        "sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" }
      }
    },
    "engineVersion": { "type": "string", "minLength": 1 },
    "engineCommitSha": { "type": "string", "pattern": "^(development|[0-9a-f]{40})$" },
    "diffFingerprintAlgorithm": { "const": "git-raw-z-v1-sha256" },
    "defaultBranch": { "type": "string", "minLength": 1 },
    "testCategories": {
      "type": "object",
      "additionalProperties": {
        "type": "array",
        "items": { "type": "string", "minLength": 1 }
      }
    },
    "highImpactMappings": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["businessPaths", "requirements"],
        "properties": {
          "businessPaths": { "type": "array", "minItems": 1, "items": { "type": "string" } },
          "requirements": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "required": ["anyOf"],
              "properties": {
                "anyOf": { "type": "array", "minItems": 1, "items": { "type": "string" } }
              }
            }
          }
        }
      }
    },
    "testEntries": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "type"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "type": { "enum": ["file", "command"] },
          "path": { "type": "string" },
          "command": { "type": "string" },
          "node": { "type": "string" }
        }
      }
    },
    "testSupport": { "type": "array", "items": { "type": "string" } },
    "testTiers": {
      "type": "object",
      "required": ["pr-blocking", "nightly", "manual-smoke"],
      "properties": {
        "pr-blocking": { "type": "array", "items": { "type": "string" } },
        "nightly": { "type": "array", "items": { "type": "string" } },
        "manual-smoke": { "type": "array", "items": { "type": "string" } }
      }
    },
    "commandAliases": {
      "type": "object",
      "additionalProperties": { "type": "array", "items": { "type": "string" } }
    },
    "prBlockingCommands": { "type": "array", "items": { "type": "string" } },
    "publicCommands": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "manifest", "command", "definitionHash", "semantics", "tier", "consumers"],
        "properties": {
          "id": { "type": "string" },
          "manifest": { "type": "string" },
          "command": { "type": "string" },
          "definitionHash": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
          "semantics": { "type": "string", "minLength": 1 },
          "tier": { "enum": ["pr-blocking", "nightly", "manual-smoke"] },
          "consumers": {
            "type": "object",
            "required": ["contractTests", "docs", "workflows"],
            "properties": {
              "contractTests": { "type": "array", "minItems": 1, "items": { "type": "string" } },
              "docs": { "type": "array", "minItems": 1, "items": { "type": "string" } },
              "workflows": { "type": "array", "minItems": 1, "items": { "type": "string" } }
            }
          }
        }
      }
    },
    "guards": { "type": "array", "items": { "type": "object" } },
    "policyChecks": { "type": "array", "items": { "type": "object" } },
    "workflowAllowedEntries": { "type": "array", "items": { "type": "string" } },
    "waiverApprovers": { "type": "array", "items": { "type": "string" } },
    "managedFiles": { "type": "array", "items": { "type": "string" } }
  },
  "$defs": {
    "runtime": {
      "type": "object",
      "required": ["id", "systemTools"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "node": {
          "type": "object",
          "required": ["version"],
          "properties": { "version": { "type": "string", "minLength": 1 } }
        },
        "python": {
          "type": "object",
          "required": ["version"],
          "properties": { "version": { "type": "string", "minLength": 1 } }
        },
        "packageManager": {
          "type": "object",
          "required": ["name", "version"],
          "properties": {
            "name": { "type": "string", "minLength": 1 },
            "version": { "type": "string", "pattern": "^\\d+\\.\\d+\\.\\d+$" }
          }
        },
        "systemTools": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["name"],
            "anyOf": [{ "required": ["version"] }, { "required": ["sha256"] }],
            "properties": {
              "name": { "type": "string", "minLength": 1 },
              "version": { "type": "string", "minLength": 1 },
              "sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
              "source": { "enum": ["system", "self-contained"] },
              "path": { "type": "string", "minLength": 1 }
            }
          }
        }
      }
    },
    "executionProfile": {
      "type": "object",
      "required": ["id", "tier", "runtimeId", "entry", "requiredStages", "dependencyPreparation", "consumers"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "tier": { "enum": ["pr-blocking", "nightly", "manual-smoke"] },
        "runtimeId": { "type": "string", "minLength": 1 },
        "entry": {
          "type": "object",
          "required": ["publicCommand", "argv"],
          "properties": {
            "publicCommand": { "type": "string", "minLength": 1 },
            "argv": { "type": "array", "minItems": 1, "items": { "type": "string" } }
          }
        },
        "requiredStages": {
          "type": "array",
          "minItems": 2,
          "items": {
            "type": "object",
            "required": ["id", "commands"],
            "properties": {
              "id": { "enum": ["dependencies", "prepare", "validate"] },
              "commands": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } }
            }
          }
        },
        "dependencyPreparation": { "$ref": "#/$defs/dependencyPreparation" },
        "consumers": { "type": "array", "items": { "$ref": "#/$defs/profileConsumer" } }
      }
    },
    "profileConsumer": {
      "oneOf": [
        {
          "type": "object",
          "required": ["type", "revisionSource"],
          "properties": {
            "type": { "const": "pre-push" },
            "revisionSource": { "const": "pushed-ref-tip" }
          }
        },
        {
          "type": "object",
          "required": ["type", "workflow", "job", "verificationStep", "trigger", "revisionSource", "executionContext"],
          "properties": {
            "type": { "const": "github-actions" },
            "workflow": { "type": "string", "minLength": 1 },
            "job": { "type": "string", "minLength": 1 },
            "verificationStep": { "type": "string", "minLength": 1 },
            "trigger": { "type": "string", "minLength": 1 },
            "revisionSource": { "enum": ["pull-request-head", "pull-request-merge", "push-event-sha"] },
            "executionContext": {
              "type": "object",
              "required": ["workingDirectory", "shell", "continueOnError", "stepIf", "jobIf", "defaultsRun", "matrix", "needs", "env", "runner", "container", "timeoutMinutes"],
              "properties": {
                "workingDirectory": { "type": "string" },
                "shell": { "type": ["string", "null"] },
                "continueOnError": { "type": "boolean" },
                "stepIf": { "type": ["string", "null"] },
                "jobIf": { "type": ["string", "null"] },
                "defaultsRun": { "type": ["object", "null"] },
                "matrix": { "type": ["object", "null"] },
                "needs": { "type": "array", "items": { "type": "string" } },
                "env": { "type": "object" },
                "runner": { "type": ["string", "array", "null"] },
                "container": { "type": ["string", "object", "null"] },
                "timeoutMinutes": { "type": ["number", "null"] }
              }
            }
          }
        }
      ]
    },
    "dependencyPreparation": {
      "type": "object",
      "required": ["id", "definitionHash", "semantics", "adapter", "workingDirectory", "env", "lifecycleScripts", "hookArgv", "ciArgv", "consumers"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "definitionHash": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
        "semantics": { "type": "string", "minLength": 1 },
        "adapter": { "type": "string", "minLength": 1 },
        "workingDirectory": { "type": "string", "minLength": 1 },
        "env": { "type": "object", "additionalProperties": { "type": "string" } },
        "lifecycleScripts": {
          "type": "object",
          "required": ["mode", "allowlist"],
          "properties": {
            "mode": { "enum": ["forbid", "allow"] },
            "allowlist": {
              "type": "array",
              "items": {
                "type": "object",
                "required": ["package", "version", "integrity", "stages"],
                "properties": {
                  "package": { "type": "string", "minLength": 1 },
                  "version": { "type": "string", "pattern": "^\\d+\\.\\d+\\.\\d+$" },
                  "integrity": { "type": "string", "minLength": 1 },
                  "stages": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } }
                }
              }
            }
          }
        },
        "hookArgv": { "type": "array", "items": { "type": "string" } },
        "ciArgv": { "type": "array", "items": { "type": "string" } },
        "consumers": {
          "type": "object",
          "required": ["contractTests", "docs", "workflows"],
          "properties": {
            "contractTests": { "type": "array", "minItems": 1, "items": { "type": "string" } },
            "docs": { "type": "array", "minItems": 1, "items": { "type": "string" } },
            "workflows": { "type": "array", "minItems": 1, "items": { "type": "string" } }
          }
        }
      }
    }
  }
}
