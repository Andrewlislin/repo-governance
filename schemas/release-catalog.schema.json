{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/CoaseEdge/repo-governance/schemas/release-catalog.schema.json",
  "title": "repo-governance signed release catalog",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "releases"],
  "properties": {
    "schemaVersion": { "const": 1 },
    "releases": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["version", "commitSha", "releasedAt", "securityFix"],
        "properties": {
          "version": {
            "type": "string",
            "pattern": "^(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)(?:-((?:0|[1-9][0-9]*|[0-9]*[A-Za-z-][0-9A-Za-z-]*)(?:\\.(?:0|[1-9][0-9]*|[0-9]*[A-Za-z-][0-9A-Za-z-]*))*))?(?:\\+[0-9A-Za-z-]+(?:\\.[0-9A-Za-z-]+)*)?$"
          },
          "commitSha": { "type": "string", "pattern": "^[0-9a-f]{40}$" },
          "releasedAt": { "type": "string", "format": "date-time" },
          "securityFix": { "type": "boolean" }
        }
      }
    }
  }
}
