{
  "name": "@andrewlislin/repo-governance",
  "version": "1.0.0",
  "description": "Deterministic repository governance shared by local hooks, Codex Skills, and GitHub Actions",
  "type": "module",
  "private": false,
  "bin": {
    "repo-governance": "bin/repo-governance.mjs"
  },
  "engines": {
    "node": "22.x"
  },
  "scripts": {
    "test": "node --test",
    "test:pr1": "node --test tests/config.test.mjs tests/dispatcher.test.mjs tests/fingerprint.test.mjs tests/hooks.test.mjs tests/init.test.mjs tests/rg001.test.mjs tests/update.test.mjs tests/waiver.test.mjs",
    "test:rg002": "node --test tests/rg002.test.mjs",
    "test:rg003": "node --test tests/rg003.test.mjs",
    "test:rg004": "node --test tests/rg004.test.mjs",
    "test:skills": "node --test tests/skills.test.mjs",
    "test:github": "node --test tests/github-waiver.test.mjs tests/github-enforce.test.mjs",
    "test:release": "node --test tests/release-install.test.mjs tests/workflow-security.test.mjs",
    "test:git-fixtures": "node --test tests/git-history.test.mjs tests/fingerprint-fixtures.test.mjs",
    "check:static": "node --check bin/repo-governance.mjs && node scripts/check-sources.mjs",
    "check": "npm run check:static && npm test",
    "build:sea": "node scripts/build-sea.mjs",
    "package:release": "node scripts/package-release.mjs",
    "install:local": "node scripts/install-local.mjs"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Andrewlislin/repo-governance.git"
  },
  "files": [
    "bin",
    "schemas",
    "presets",
    "src",
    "templates"
  ],
  "dependencies": {
    "yaml": "2.8.1"
  },
  "devDependencies": {
    "esbuild": "0.28.1",
    "postject": "1.0.0-alpha.6"
  }
}
