{
  "schemaVersion": 1,
  "name": "react-web",
  "description": "React web application with frontend behavior and build verification boundaries.",
  "requiredSelectors": [],
  "optionalSelectors": [
    { "id": "package", "type": "file", "path": "package.json" },
    { "id": "test-command", "type": "package-script", "manifest": "package.json", "command": "test" },
    { "id": "static-command", "type": "package-script", "manifest": "package.json", "command": "check:static" },
    { "id": "build-command", "type": "package-script", "manifest": "package.json", "command": "build" }
  ],
  "testCategories": {
    "unit": ["tests/unit/**", "src/**/*.test.ts", "src/**/*.test.tsx"],
    "frontend": ["tests/frontend/**", "tests/e2e/**"],
    "contract": ["tests/contract/**"],
    "command-contract": ["tests/commands/**"],
    "build-verification": ["tests/build/**"]
  },
  "highImpactMappings": [
    { "businessPaths": ["src/components/**", "src/pages/**", "src/routes/**", "src/hooks/**"], "requirements": [{ "anyOf": ["frontend", "unit"] }] },
    { "businessPaths": ["package.json", "vite.config.*", "next.config.*", "webpack.config.*"], "requirements": [{ "anyOf": ["command-contract"] }, { "anyOf": ["build-verification"] }] }
  ],
  "testEntries": [],
  "testSupport": ["tests/fixtures/**", "tests/helpers/**"],
  "testTiers": { "pr-blocking": [], "nightly": [], "manual-smoke": [] },
  "commandAliases": {},
  "publicCommandCandidates": [
    { "id": "test", "selector": "test-command", "manifest": "package.json", "command": "test", "semantics": "Runs deterministic React tests.", "tier": "pr-blocking", "consumers": { "contractTests": ["tests/commands/**"], "docs": ["README.md", "README.zh-CN.md"], "workflows": [".github/workflows/**"] } },
    { "id": "check-static", "selector": "static-command", "manifest": "package.json", "command": "check:static", "semantics": "Runs deterministic frontend static checks.", "tier": "pr-blocking", "consumers": { "contractTests": ["tests/commands/**"], "docs": ["README.md", "README.zh-CN.md"], "workflows": [".github/workflows/**"] } },
    { "id": "build", "selector": "build-command", "manifest": "package.json", "command": "build", "semantics": "Builds production web assets.", "tier": "pr-blocking", "consumers": { "contractTests": ["tests/commands/**"], "docs": ["README.md", "README.zh-CN.md"], "workflows": [".github/workflows/**"] } }
  ],
  "workflowAllowedEntryTemplates": ["uses:CoaseEdge/repo-governance/.github/workflows/governance.yml@{engineCommitSha}"],
  "hookStrategy": "connect-effective-pre-push",
  "ciCaller": { "provider": "github-actions", "commentReporter": false }
}
